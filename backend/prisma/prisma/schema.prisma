generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Card {
  id        String   @id @default(cuid())
  name      String
  cardClass String
  data      String   // JSON blob of full CardData
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
